# ─── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=assistify_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app

# ─── RAG / LLM (Required for AI chatbot) ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MAX_HISTORY_TURNS=10
RETRIEVAL_TOP_K=5
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.6

# ─── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token
SHOPIFY_API_VERSION=2026-04

# ─── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Facebook Messenger ────────────────────────────────────────────────────────
MESSENGER_PAGE_ACCESS_TOKEN=your_token
MESSENGER_APP_SECRET=your_secret
MESSENGER_VERIFY_TOKEN=assistify_webhook_verify_token
